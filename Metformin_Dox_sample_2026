yr <- range(d_all$predicted_age, na.rm = TRUE); span <- diff(yr); if (span == 0) span <- 1
y_br  <- yr[2] + span * 0.06     # 括号高度（两图一致）
y_tx  <- yr[2] + span * 0.10     # 文字高度
