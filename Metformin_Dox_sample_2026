plot_ct_box <- function(ct) {
    d <- cell_pred[cell_pred$celltype == ct & cell_pred$sample_info %in% x_levels, ]
    d$sample_info <- factor(d$sample_info, levels = x_levels)

    # Control vs TamDox（同 strain 内）Wilcoxon
    p_b6  <- tryCatch(wilcox.test(predicted_age ~ sample_info,
                     data = droplevels(d[d$sample_info %in% x_levels[1:2], ]))$p.value, error = function(e) NA)
    p_cd1 <- tryCatch(wilcox.test(predicted_age ~ sample_info,
                     data = droplevels(d[d$sample_info %in% x_levels[3:4], ]))$p.value, error = function(e) NA)

    ggplot(d, aes(x = sample_info, y = predicted_age, fill = sample_info)) +
        geom_boxplot(width = 0.6, outlier.size = 0.3, alpha = 0.85) +
        scale_fill_manual(values = box_cols, guide = "none") +
        # B6 比较（x 1-2）
        annotate("segment", x = 1, xend = 2, y = y_br, yend = y_br) +
        annotate("text", x = 1.5, y = y_tx, label = fmt_p(p_b6), size = 4) +
        # CD1 比较（x 3-4）
        annotate("segment", x = 3, xend = 4, y = y_br, yend = y_br) +
        annotate("text", x = 3.5, y = y_tx, label = fmt_p(p_cd1), size = 4) +
        coord_cartesian(ylim = y_lim) +           # 两图统一 y 轴范围
        labs(title = ct, x = NULL, y = "Predicted age (weeks)") +
        theme_classic(base_size = 13) +
        theme(axis.text.x = element_text(angle = 30, hjust = 1, color = "black"),
              axis.text.y = element_text(color = "black"),
              plot.title  = element_text(hjust = 0.5, face = "bold", size = 15))
}

