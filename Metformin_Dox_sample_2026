######## 逐 cell type 预测每个细胞的年龄 ########
######################################################################
seu_celltypes <- unique(as.character(seu_dox$celltype))
pred_list <- list()

for (ct_clock in clock_celltypes) {
    # 找到 seu_dox 中对应此 clock celltype 的名字
    ct_data <- names(celltype_map)[celltype_map == ct_clock]
    ct_data <- intersect(ct_data, seu_celltypes)
    if (length(ct_data) == 0) { message(ct_clock, ": seu_dox 中无对应 celltype，跳过"); next }

    model_file <- file.path(clock_dir, ct_clock, sprintf("%s_final_aging_clock_model_2026.rds", ct_clock))
    if (!file.exists(model_file)) { message(ct_clock, ": final 模型不存在，跳过 -> ", model_file); next }

    cells <- colnames(seu_dox)[as.character(seu_dox$celltype) %in% ct_data]
    if (length(cells) == 0) next
    seu_ct <- subset(seu_dox, cells = cells)

    # === 关键：先按 sample 做 KNN smoothing（与训练同款），再预测 ===
    sp <- smooth_params(ct_clock)
    message(sprintf("\n%s: 原始 %d 细胞，开始 KNN smoothing ...", ct_clock, ncol(seu_ct)))
    seu_ct_sm <- smooth_celltype_by_sample(seu_ct, k = sp$k, npcs = sp$npcs, sample_col = "sample_info")
    if (is.null(seu_ct_sm)) { message(ct_clock, ": smoothing 后无有效细胞，跳过"); next }

    final_model_obj <- readRDS(model_file)
    res <- predict_final_clock(final_model_obj, seu_ct_sm, ambient_genes = M_ambient_genes_Top50)

    df <- data.frame(
        cell        = names(res$pred),
        celltype    = ct_clock,
        sample_info = as.character(seu_ct_sm$sample_info),
        treatment   = as.character(seu_ct_sm$treatment),
        strain      = as.character(seu_ct_sm$strain),
        sex         = as.character(seu_ct_sm$sex),
        predicted_age = res$pred,
        stringsAsFactors = FALSE
    )
    pred_list[[ct_clock]] <- df
    message(sprintf("%s: smoothed %d 个 pseudo-cell 预测完成 (缺失基因 %d/%d)", ct_clock, nrow(df), res$n_missing_genes, res$n_genes))
}

