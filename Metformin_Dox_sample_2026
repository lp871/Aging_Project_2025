######################################################################
######## KNN smoothing 辅助函数（与 mouse 训练预处理完全一致）########
######################################################################
library(FNN)

NormalizeAndPCA <- function(seu, norm.method = "LogNormalize", scale.factor = 1e4,
                            nfeatures = 2000, npcs = 30) {
    seu <- NormalizeData(seu, normalization.method = norm.method, scale.factor = scale.factor, verbose = FALSE)
    seu <- FindVariableFeatures(seu, selection.method = "vst", nfeatures = nfeatures, verbose = FALSE)
    seu <- ScaleData(seu, features = rownames(seu), verbose = FALSE)
    n_cells <- ncol(seu); n_genes <- nrow(seu)
    max_npcs <- min(n_genes, n_cells) - 1
    if (npcs > max_npcs) npcs <- max(1, max_npcs)
    if (npcs < 1) stop(sprintf("细胞数太少 (n_cells=%d)，无法进行 PCA", n_cells))
    seu <- RunPCA(seu, features = VariableFeatures(seu), npcs = npcs, verbose = FALSE)
    seu
}

PseudoBulkByKNN_fast <- function(seu, k = 15, dims = 1:30, assay = "RNA", reduction = "pca") {
    emb <- Embeddings(seu, reduction)[, dims, drop = FALSE]
    knn <- get.knn(emb, k = k)
    nn_idx <- knn$nn.index
    ncells <- nrow(nn_idx)
    rows <- as.integer(c(t(nn_idx), seq_len(ncells)))
    cols <- rep(seq_len(ncells), each = k + 1)
    A <- sparseMatrix(i = rows, j = cols, x = 1, dims = c(ncells, ncells))
    counts_mat <- GetAssayData(seu, assay = assay, layer = "counts")
    pseudo_counts <- counts_mat %*% A
    CreateSeuratObject(counts = pseudo_counts, meta.data = seu@meta.data, assay = assay)
}

# 每个 celltype 的 smoothing 参数（与训练一致）
smooth_params <- function(ct) {
    if (ct %in% c("Rod", "AC", "HC", "BC", "Cone", "RGC")) return(list(k = 15, npcs = 25))
    if (ct == "MG") return(list(k = 5, npcs = 5))
    list(k = 15, npcs = 25)   # 默认
}

# 对单个 celltype 的对象：按 sample 拆分 -> KNN smoothing -> merge（复刻训练动态调整逻辑）
smooth_celltype_by_sample <- function(seu_ct, k, npcs, sample_col = "sample_info") {
    DefaultAssay(seu_ct) <- "RNA"
    if ("layers" %in% slotNames(seu_ct[["RNA"]])) seu_ct[["RNA"]] <- JoinLayers(seu_ct[["RNA"]])
    tmp_sp <- SplitObject(seu_ct, split.by = sample_col)
    nc <- sapply(tmp_sp, ncol)
    tmp_sp <- tmp_sp[nc >= 2]                        # 去掉 <2 细胞的样本
    if (length(tmp_sp) == 0) return(NULL)
    min_ncells <- min(sapply(tmp_sp, ncol))
    # 细胞太少（<5）：跳过 smooth，直接 merge
    if (min_ncells < 5) {
        message(sprintf("    最小样本细胞数 %d < 5，跳过 smooth 直接 merge", min_ncells))
        if (length(tmp_sp) == 1) return(tmp_sp[[1]])
        return(merge(tmp_sp[[1]], tmp_sp[-1], add.cell.ids = names(tmp_sp)))
    }
    if (npcs >= min_ncells) npcs <- max(1, min_ncells - 1)
    if (k >= min_ncells)   k    <- max(1, min_ncells - 1)
    message(sprintf("    smoothing: k=%d, npcs=%d (min cells/sample=%d)", k, npcs, min_ncells))
    tmp_sp_res    <- sapply(tmp_sp, NormalizeAndPCA, npcs = npcs)
    tmp_sp_pseudo <- sapply(tmp_sp_res, PseudoBulkByKNN_fast, k = k, dims = 1:npcs)
    if (length(tmp_sp_pseudo) == 1) {
        out <- tmp_sp_pseudo[[1]]
    } else {
        out <- merge(tmp_sp_pseudo[[1]], tmp_sp_pseudo[-1], add.cell.ids = names(tmp_sp_pseudo))
    }
    if ("layers" %in% slotNames(out[["RNA"]])) out[["RNA"]] <- JoinLayers(out[["RNA"]])
    out
}


######################################################################
######## 预测函数：与 Train_Final_AgingClock 训练流程完全一致（无校准）########
######################################################################
predict_final_clock <- function(final_model_obj, seu_ct, ambient_genes = NULL) {
    counts <- GetAssayData(seu_ct, assay = "RNA", layer = "counts")
    # 去 ambient（与训练一致，depth 在去 ambient 后计算）
    if (!is.null(ambient_genes)) {
        ag <- intersect(ambient_genes, rownames(counts))
        if (length(ag) > 0) counts <- counts[!rownames(counts) %in% ag, , drop = FALSE]
    }
    # depth normalization 1e4 + log2(1+x)
    depth <- Matrix::colSums(counts); depth[depth == 0] <- 1
    counts_norm <- sweep(counts, 2, depth / 1e4, FUN = "/")
    counts_log2 <- log2(1 + counts_norm)
    # 按训练基因（genes_used）对齐，缺失基因补 0
    genes <- final_model_obj$genes_used
    present <- intersect(genes, rownames(counts_log2))
    missing <- setdiff(genes, rownames(counts_log2))
    mat <- counts_log2[present, , drop = FALSE]
    if (length(missing) > 0) {
        zero_mat <- Matrix::Matrix(0, nrow = length(missing), ncol = ncol(counts_log2), sparse = TRUE)
        rownames(zero_mat) <- missing
        mat <- rbind(mat, zero_mat)
    }
    mat <- mat[genes, , drop = FALSE]     # 严格按训练顺序
    X <- t(as.matrix(mat))
    # Z-score（用训练时保存的 means/sds）
    if (isTRUE(final_model_obj$standardization$enabled)) {
        X <- scale(X, center = final_model_obj$standardization$means,
                   scale = final_model_obj$standardization$sds)
    }
    pred <- as.numeric(predict(final_model_obj$model, newx = X, s = final_model_obj$lambda))
    names(pred) <- colnames(mat)
    list(pred = pred, n_missing_genes = length(missing), n_genes = length(genes))
}


