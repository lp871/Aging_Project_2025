import os
import numpy as np
import scipy.sparse as sp
import scanpy as sc

h5ad_dir = "/projects/hmz-aging/Human_New_Datasets/celltype_h5ad"
celltypes_all = ['AC', 'BC', 'RGC', 'Rod', 'Cone', 'HC', 'MG', 'Microglia', 'RPE']

def _is_counts(X, n_sample=200000):
    data = X.data if sp.issparse(X) else np.asarray(X).ravel()
    if data.size == 0:
        return True, 0.0, 0.0
    s = data if data.size <= n_sample else data[np.random.choice(data.size, n_sample, replace=False)]
    all_int = bool(np.all(np.mod(s, 1) == 0))
    any_neg = bool(np.min(data) < 0)
    return (all_int and not any_neg), float(np.min(data)), float(np.max(data))

print("\n" + "="*70)
print("验证所有 clean5：X 是否 raw counts + 基因是否一致")
gene_lists = {}
shapes = {}
for ct in celltypes_all:
    clean5_file = os.path.join(h5ad_dir, f"{ct}_clean5.h5ad")
    if not os.path.exists(clean5_file):
        print(f"  {ct}: clean5 不存在，跳过 -> {clean5_file}")
        continue
    a = sc.read_h5ad(clean5_file)
    is_cnt, mn, mx = _is_counts(a.X)
    gene_lists[ct] = a.var.index.tolist()
    shapes[ct] = a.shape
    print(f"  {ct}: {a.shape[0]} 细胞 x {a.shape[1]} 基因; X min={mn:.4f}, max={mx:.4f}, 是raw counts: {is_cnt}")
    del a

#### 各 celltype 基因是否完全一致（集合 + 顺序） ####
print("\n--- 基因一致性检查 ---")
