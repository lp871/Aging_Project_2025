    ref_ct = next(iter(gene_lists))
    ref_genes = gene_lists[ref_ct]
    ref_set = set(ref_genes)
    all_same_set = True
    all_same_order = True
    for ct, genes in gene_lists.items():
        same_set = (set(genes) == ref_set)
        same_order = (genes == ref_genes)
