import os
import numpy as np
import pandas as pd
import scanpy as sc
from scipy import sparse

out_dir = "/projects/hmz-aging/Figure1E_pseudobulk"
os.makedirs(out_dir, exist_ok=True)

def pseudobulk_sum(adata, celltype_col="celltype"):
    #### 返回 DataFrame: gene(index) x celltype，值=该 celltype 所有细胞 raw counts 之和 ####
    X = adata.X.tocsr() if sparse.issparse(adata.X) else sparse.csr_matrix(adata.X)
    cats = adata.obs[celltype_col].astype(str)
    out = {}
    for ct in sorted(cats.unique()):
        idx = np.where((cats == ct).values)[0]
        if idx.size == 0:
            continue
        out[ct] = np.asarray(X[idx].sum(axis=0)).ravel()
        print(f"    {ct}: {idx.size} 细胞")
    df = pd.DataFrame(out, index=adata.var_names)
    df.index.name = "gene"
    return df

