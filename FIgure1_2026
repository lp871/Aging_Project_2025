for ct in celltypes_all:
    print("\n" + "="*70)
    print(f"=== 处理 {ct} ===")
    base_file   = os.path.join(h5ad_dir, f"{ct}.h5ad")
    clean3_file = os.path.join(h5ad_dir, f"{ct}_clean3.h5ad")
    clean4_file = os.path.join(h5ad_dir, f"{ct}_clean4.h5ad")
    if not os.path.exists(base_file):
        print(f"  [跳过] 原始文件不存在: {base_file}")
        continue
    if not os.path.exists(clean3_file):
        print(f"  [跳过] clean3 不存在: {clean3_file}")
        continue
    if not os.path.exists(clean4_file):
        print(f"  [跳过] clean4 不存在: {clean4_file}")
        continue
    #### 1) 从 clean4 拿目标基因集（=已合并的 overlap symbol 集，含最终顺序） ####
    c4 = sc.read_h5ad(clean4_file, backed='r')
    target_symbols = c4.var.index.tolist()
    overlap_genes_set = set(target_symbols)
    c4_ncells = c4.shape[0]
    c4.file.close()
    print(f"  clean4 目标基因数: {len(target_symbols)}, clean4 细胞数: {c4_ncells}")
    #### 2) 从 clean3 拿细胞 barcodes 和 obs（clean5 的 obs 与 clean3 完全一致） ####
    c3 = sc.read_h5ad(clean3_file, backed='r')
    clean3_barcodes = c3.obs_names.tolist()
    clean3_obs = c3.obs.copy()
    c3.file.close()
    print(f"  clean3 细胞数: {len(clean3_barcodes)}, obs 列: {clean3_obs.columns.tolist()}")
    #### 3) 读原始文件，取 raw counts 放进 X ####
    #### backed 读取：本数据集 raw.X 损坏，完整读取会崩，这里只物化 X/layer/obs/var，绕开 raw ####
    a_bk = sc.read_h5ad(base_file, backed='r')
    print(f"  原始 {ct}.h5ad: {a_bk.shape[0]} 细胞, {a_bk.shape[1]} 基因")
    print(f"    layers: {list(a_bk.layers.keys())}, raw is None: {a_bk.raw is None}")
    counts, src = get_raw_counts(a_bk)
    counts = counts[:]  # backed -> 物化为内存矩阵
    if not sp.issparse(counts):
        counts = sp.csr_matrix(counts)
    else:
        counts = counts.tocsr()
    is_cnt, cmin, cmax = looks_like_counts(counts)
    print(f"    raw counts 来源: {src}; min={cmin:.4f}, max={cmax:.4f}, 看起来是counts: {is_cnt}")
    if not is_cnt:
        print(f"    [警告] {src} 取到的矩阵不像 raw counts，请人工核对！")
    src_obs = a_bk.obs.copy()
    src_var = a_bk.var.copy()
    a_bk.file.close()
    del a_bk
    #### 用 counts 重建 adata（丢掉原 X/layers/raw，避免混淆），保留 var ####
    adata = ad.AnnData(X=counts, obs=src_obs, var=src_var)
    #### 4) 按 clean3 的 barcodes 精确过滤细胞，且顺序与 clean3 完全一致 ####
    src_bc_set = set(adata.obs_names)
    missing = [bc for bc in clean3_barcodes if bc not in src_bc_set]
    if len(missing) > 0:
        print(f"    [警告] clean3 有 {len(missing)} 个 barcode 不在原始文件中，示例: {missing[:5]}")
    keep = [bc for bc in clean3_barcodes if bc in src_bc_set]
    adata = adata[keep, :].copy()
    cells_match = (adata.obs_names.tolist() == clean3_barcodes)
    print(f"    过滤后细胞数: {adata.shape[0]}; 与 clean3 完全一致(数量+顺序): {cells_match}")
    #### 用 clean3 的 obs（统一列名版）覆盖，保证 clean5 的 obs 与 clean3 一致 ####
    adata.obs = clean3_obs.loc[adata.obs_names].copy()
    #### 5) 与 clean4 相同的基因逻辑：overlap 基因 + 合并重复 gene symbol ####
    if ct == "RPE":
        # RPE 的 var 索引已是 Gene Symbol，直接筛 overlap
        genes_to_keep = [g for g in adata.var.index if g in overlap_genes_set]
        adata_c5 = adata[:, genes_to_keep].copy()
        print(f"    [RPE] 直接筛 overlap 基因: {adata_c5.shape[1]}")
    else:
        # 非 RPE：Ensembl -> Symbol，合并相同 symbol 的 counts（求和）
        ensembl_ids = adata.var.index.tolist()
        gene_symbols = [gene_map_dict.get(eid, eid) for eid in ensembl_ids]
        mask = [gs in overlap_genes_set for gs in gene_symbols]
        filtered_ensembl = [eid for eid, m in zip(ensembl_ids, mask) if m]
        filtered_symbols = [gs for gs, m in zip(gene_symbols, mask) if m]
        print(f"    过滤到 overlap: {len(filtered_ensembl)} 个 Ensembl ID")
        symbol_to_indices = defaultdict(list)
        for i, sym in enumerate(filtered_symbols):
            symbol_to_indices[sym].append(i)
        unique_symbols = sorted(symbol_to_indices.keys())
        n_dup = sum(1 for s in unique_symbols if len(symbol_to_indices[s]) > 1)
        print(f"    需合并的重复 symbol 数: {n_dup}; 合并后 unique symbol: {len(unique_symbols)}")
        adata_filtered = adata[:, filtered_ensembl].copy()
        X = adata_filtered.X
        X = X.tocsc() if sp.issparse(X) else sp.csc_matrix(X)
        row_idx, col_idx = [], []
        for j, sym in enumerate(unique_symbols):
            for i in symbol_to_indices[sym]:
                row_idx.append(i)
                col_idx.append(j)
        agg_mat = sp.csr_matrix(
            (np.ones(len(row_idx)), (row_idx, col_idx)),
            shape=(len(filtered_symbols), len(unique_symbols))
        )
        new_X = sp.csr_matrix(X @ agg_mat)
        adata_c5 = ad.AnnData(X=new_X, obs=adata_filtered.obs.copy())
        adata_c5.var_names = pd.Index(unique_symbols)
        print(f"    [非RPE] 合并后基因数: {adata_c5.shape[1]}")
        del adata_filtered, X, agg_mat, new_X
    #### 6) 基因顺序对齐到 clean4，保证 clean5 与 clean4 的 var 完全一致 ####
    have = set(adata_c5.var_names)
    missing_genes = [g for g in target_symbols if g not in have]
    if len(missing_genes) > 0:
        print(f"    [警告] 有 {len(missing_genes)} 个 clean4 基因在重建结果中缺失，示例: {missing_genes[:5]}")
        target_use = [g for g in target_symbols if g in have]
    else:
        target_use = target_symbols
    adata_c5 = adata_c5[:, target_use].copy()
