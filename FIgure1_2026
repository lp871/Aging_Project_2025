            print(f"  {ct}: 基因集合与 {ref_ct} 不一致 (多 {len(set(genes)-ref_set)}, 缺 {len(ref_set-set(genes))})")
        elif not same_order:
            all_same_order = False
            print(f"  {ct}: 基因集合相同但顺序与 {ref_ct} 不同")
    print(f"\n  参考 {ref_ct}: {len(ref_genes)} 个基因")
    print(f"  所有 celltype 基因集合一致: {all_same_set}")
    print(f"  所有 celltype 基因顺序一致: {all_same_set and all_same_order}")

