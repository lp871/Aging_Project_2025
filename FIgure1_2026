    "Microglia": "#3BB6AE",
}
STACK_ORDER = ["Rod", "BC", "AC", "Cone", "HC", "RGC", "MG", "Microglia", "RPE"]
_fallback = ["#1B9E77", "#D95F02", "#7570B3", "#E7298A", "#66A61E", "#E6AB02", "#A6761D", "#666666"]

def stacked_bar(counts, order_tp, out_png, out_pdf, xlabel="", figsize=(9, 4)):
    #### counts: DataFrame，index=timepoint(str)，columns=celltype，值=细胞数 ####
    present_ct = [c for c in STACK_ORDER if c in counts.columns] + \
                 [c for c in counts.columns if c not in STACK_ORDER]
    fb = itertools.cycle(_fallback)
    pal = {c: celltype_palette.get(c, next(fb)) for c in present_ct}
    counts = counts.reindex(index=order_tp, columns=present_ct).fillna(0)
    x = np.arange(len(order_tp))
    fig, ax = plt.subplots(figsize=figsize)
    bottom = np.zeros(len(order_tp))
    for ct in present_ct:
        vals = counts[ct].values.astype(float)
        ax.bar(x, vals, bottom=bottom, width=0.8, color=pal[ct], alpha=0.5, label=ct, edgecolor="none")
        bottom += vals
    ax.set_xticks(x)
    ax.set_xticklabels(order_tp, fontsize=20)          # x 轴字大
    ax.tick_params(axis="y", labelsize=18)             # y 轴字大
    ax.set_xlabel(xlabel, fontsize=14)
    ax.set_xlim(-0.6, len(order_tp) - 0.4)
    ax.margins(y=0)
    #### y 轴科学计数法，并把指数标记(如 ×10⁴)直接并入 y 轴标题 ####
    ax.ticklabel_format(axis="y", style="sci", scilimits=(0, 0))
    fig.canvas.draw()                                  # 触发计算 offset 文本
    _off = ax.yaxis.get_offset_text().get_text()       # 形如 '1e4'
    ax.yaxis.get_offset_text().set_visible(False)      # 隐藏右上角的指数
    _ylab = "cell numbers"
    if _off:
        try:
            _exp = int(_off.split("e")[1])
            _sup = str(_exp).translate(str.maketrans("0123456789-", "⁰¹²³⁴⁵⁶⁷⁸⁹⁻"))
            _ylab = f"cell numbers (×10{_sup})"
        except Exception:
            _ylab = f"cell numbers ({_off})"
    ax.set_ylabel(_ylab, fontsize=20)
    for sp in ax.spines.values():
        sp.set_visible(True); sp.set_color("black"); sp.set_linewidth(1.2)
    ax.legend(bbox_to_anchor=(1.01, 1), loc="upper left", frameon=False, fontsize=11)
    fig.savefig(out_png, dpi=600, bbox_inches="tight")
    fig.savefig(out_pdf, bbox_inches="tight")
    plt.close(fig)
    print(f"已保存: {out_png}")

