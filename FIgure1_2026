import os
import numpy as np
import scipy.sparse as sp
import scanpy as sc

h5ad_dir = "/projects/hmz-aging/Human_New_Datasets/celltype_h5ad"
celltypes_all = ['AC', 'BC', 'RGC', 'Rod', 'Cone', 'HC', 'MG', 'Microglia', 'RPE']

#### 判断一个矩阵是否像 raw counts：非负 + 全整数 ####
def check_is_raw_counts(X, n_sample=200000):
    if sp.issparse(X):
        data = X.data
    else:
        data = np.asarray(X).ravel()
    if data.size == 0:
        return {"n_nonzero": 0, "min": 0.0, "max": 0.0, "all_integer": True, "any_negative": False}
    # 只抽样一部分非零值判断（大矩阵省时）
    if data.size > n_sample:
        idx = np.random.choice(data.size, n_sample, replace=False)
        sample = data[idx]
    else:
        sample = data
    all_integer = bool(np.all(np.mod(sample, 1) == 0))
    any_negative = bool(np.min(data) < 0)
    return {
        "n_nonzero": int(data.size),
        "min": float(np.min(data)),
        "max": float(np.max(data)),
        "all_integer": all_integer,
        "any_negative": any_negative,
    }

for ct in celltypes_all:
    clean4_file = os.path.join(h5ad_dir, f"{ct}_clean4.h5ad")
    if not os.path.exists(clean4_file):
        print(f"{ct}: clean4 not found, skipping")
        continue
    adata = sc.read_h5ad(clean4_file)
    info = check_is_raw_counts(adata.X)
    is_raw = info["all_integer"] and not info["any_negative"]
    print(f"\n=== {ct}_clean4 ===")
    print(f"  X dtype: {adata.X.dtype}, shape: {adata.shape}")
    print(f"  layers: {list(adata.layers.keys())}, raw is None: {adata.raw is None}")
    print(f"  X min={info['min']:.4f}, max={info['max']:.4f}, "
          f"all_integer={info['all_integer']}, any_negative={info['any_negative']}")
    print(f"  => 看起来是 raw counts: {is_raw}")
    del adata


