#### 从 adata 里取出 raw counts：优先 layers['counts']/['raw_counts']，再 .raw，最后 .X ####
#### 注意：本数据集的 .raw 元数据存在但 raw.X 数据集损坏，访问会报错，这里用 try 兜住 ####
def get_raw_counts(adata):
    if 'counts' in adata.layers:
        return adata.layers['counts'], "layers['counts']"
    if 'raw_counts' in adata.layers:
        return adata.layers['raw_counts'], "layers['raw_counts']"
    if adata.raw is not None:
        try:
            rx = adata.raw.X
            _ = rx[:1]  # 真正读一小块，坏掉会在这里抛错
            return rx, ".raw.X"
        except Exception as e:
            print(f"    [.raw.X 不可用，跳过] {e}")
    return adata.X, ".X (fallback)"


#### 判断矩阵是否像 raw counts：非负 + 全整数（抽样） ####
def looks_like_counts(X, n_sample=200000):
    data = X.data if sp.issparse(X) else np.asarray(X).ravel()
    if data.size == 0:
        return True, 0.0, 0.0
    sample = data if data.size <= n_sample else data[np.random.choice(data.size, n_sample, replace=False)]
    all_integer = bool(np.all(np.mod(sample, 1) == 0))
    any_negative = bool(np.min(data) < 0)
    return (all_integer and not any_negative), float(np.min(data)), float(np.max(data))


#### 诊断：逐个 {ct}.h5ad，把 .X / 每个 layer / .raw 的数值情况都打出来，确认 raw counts 在哪 ####
def _describe_mat(name, M):
    is_cnt, mn, mx = looks_like_counts(M)
    dtype = M.dtype if hasattr(M, "dtype") else type(M)
    print(f"    [{name}] shape={M.shape}, dtype={dtype}, min={mn:.4f}, max={mx:.4f}, 是raw counts: {is_cnt}")

