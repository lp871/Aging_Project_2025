####### R: logCPM 归一化 -> 1-Pearson 距离 -> 层次聚类(average) -> ggtree 环形树 ####
#######
## 若上面 combined 还在内存里可跳过下一行；否则重新读入
combined <- readRDS(file.path(pb_dir, "HMZ_celltype_pseudobulk_humanGene.rds"))

#### 1) logCPM 归一化（列=样本 celltype*species）####
libsize <- colSums(combined)
cpm     <- sweep(combined, 2, libsize, "/") * 1e6
logcpm  <- log2(cpm + 1)

#### 2) cell type specific genes：每个物种内、每个 celltype 取 top 25 特异基因 ####
sp_of_col  <- sub("_.*$", "", colnames(logcpm))  # 每列所属物种: H / M / Z
n_ct_genes <- 10                                # 每个 celltype 取的特异基因数

marker_list <- list()
for (s in unique(sp_of_col)) {
  sub <- logcpm[, sp_of_col == s, drop = FALSE]  # 该物种 gene x celltype
  mu  <- rowMeans(sub)
  sdv <- apply(sub, 1, sd); sdv[sdv == 0 | is.na(sdv)] <- NA
  zsc <- (sub - mu) / sdv                        # 每个 celltype 相对该物种其他 celltype 的特异性
  for (j in seq_len(ncol(sub))) {
    v   <- zsc[, j]; v <- v[!is.na(v)]
    top <- names(sort(v, decreasing = TRUE))[seq_len(min(n_ct_genes, length(v)))]
    marker_list[[colnames(sub)[j]]] <- top
  }
}
for (nm in names(marker_list)) cat(nm, ":", length(marker_list[[nm]]), "\n")

hvg_sel <- unique(unlist(marker_list))           # 所有物种所有 celltype 特异基因并集
logcpm  <- logcpm[hvg_sel, , drop = FALSE]
cat("cell type specific 基因并集:", nrow(logcpm), "\n")

#### 2-1) 每个物种内，对每个基因做 z-score（跨该物种 celltype 列）####
## 放在 HVG 之后：z-score 后物种内每个基因方差都=1，会破坏基于方差的 HVG 选择
## 作用：消除物种间基因表达量级差异，让三物种可比
zmat <- logcpm
for (s in unique(sp_of_col)) {
  idx <- which(sp_of_col == s)
  sub <- logcpm[, idx, drop = FALSE]
  mu  <- rowMeans(sub)
  sdv <- apply(sub, 1, sd)
  sdv[sdv == 0 | is.na(sdv)] <- 1        # 该物种内无变化的基因 -> z=0
  zmat[, idx] <- (sub - mu) / sdv
}
cat("已按物种做基因 z-score, 维度:", dim(zmat), "\n")

#### 3) 1 - Pearson 相关作为距离（基于 z-score 矩阵）####
pcor <- cor(zmat, method = "pearson")
d    <- as.dist(1 - pcor)

#### 4) 层次聚类 ####
hc <- hclust(d, method = "average")

