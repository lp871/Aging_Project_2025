#### 把某物种 pseudobulk (gene x celltype) 转到 human 基因空间 ####
#### 一对多：同一物种基因复制到每个 human 基因；多对一：同一 human 基因相加（与 DEG rank 惯例一致）####

convert_to_human <- function(mat, map, sp_col) {
  map <- map[map[[sp_col]] %in% rownames(mat), ]
  expr <- as.matrix(mat[map[[sp_col]], , drop = FALSE])   # 按 map 复制物种基因行
  agg  <- rowsum(expr, group = map$human)                 # 同一 human 多行相加
  agg
}

